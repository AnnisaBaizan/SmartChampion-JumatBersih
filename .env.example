# Salin file ini ke .env lalu isi nilainya
# cp .env.example .env

# URL Google Apps Script (didapat setelah deploy GAS sebagai Web App)
GAS_URL=https://script.google.com/macros/s/XXXXXXXXXXXXXXXX/exec

# Password halaman admin / reset dashboard
ADMIN_PASSWORD=ganti_password_anda

# (Opsional) URL Google Form "Lapor Bug" — tombol di pojok kanan bawah
# Kosongkan untuk menyembunyikan tombol ini
BUG_URL=
